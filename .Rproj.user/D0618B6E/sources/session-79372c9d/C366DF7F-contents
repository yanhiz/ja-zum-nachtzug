# Ouvrir une grammaire
opengram <- function(path){
  read_delim(path,skip=6,delim=' ',col_names = str_c('c',seq(1,8))) %>%
    select(c3,c4) %>%
    rename(constraint=c3,rank=c4) %>%
    drop_na() %>%
    mutate(rank=as.numeric(rank)) %>%
    filter(!(rank<10&rank>-10)) %>%
    mutate(weight=rank-min(rank)+1)
}





# Ouvrir une distribution
opendistrib <- function(path,div=1000){
  read_delim(path,skip=5,delim = '=',col_names = c('name','value')) %>%
    drop_na() %>%
    pivot_wider(names_from = 'name',values_from = 'value') %>%
    unnest_longer(everything()) %>%
    rename(input=1,output=2,weight=3) %>%
    mutate(across(everything(),~str_remove_all(.x,'[ "\\\\]'))) %>%
    mutate(weight=as.numeric(weight)/div)
}

