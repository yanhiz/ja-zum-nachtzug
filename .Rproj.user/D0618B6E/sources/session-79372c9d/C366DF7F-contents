## Récupérer les valeurs de contraste d'une liste de vecteurs

take_values <- function(list){
  for (vector in list) {
    contrast <- contrasts(vector)
    for (value in row.names(contrast)){
      assign(value,contrast[value,],envir = .GlobalEnv)
    }
  }
}


