## Fonctions générales
geo_mean <- function(x){
  exp(mean(log(x)))
}

moyenne <- function (data,facteur) {
  # Moyenne d'une variable continue
  data%>%
    summarise(mean=mean({{facteur}},na.rm=T),se=sd({{facteur}},na.rm=T)/sqrt(length({{facteur}})),n=length({{facteur}}))
}

