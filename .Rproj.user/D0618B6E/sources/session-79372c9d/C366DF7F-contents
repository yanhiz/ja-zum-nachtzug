  # Inverse les noms des colonnes et les valeurs
  model %>%
    pivot_longer(everything(),names_to = 'parameter',values_to = 'estimate',names_ptypes = factor(),names_prefix = pref)
}


summarize_model <- function(model,...,m=median,rounding=2,ci=F,ci_sep='; '){
  model %>%
    summarise(e=m(estimate),
              low=ci(estimate)[[2]],
              up=ci(estimate)[[3]],
              p=max(mean(estimate>0),mean(estimate<0)),
              ...,
              .by = parameter
    ) %>%
    mutate_if(is.numeric,round,rounding) -> model
  if (ci){
    model %>%
      transmutate(ci=str_c('[',low,ci_sep,up,']'),.before=low) -> model
  }
  model
}

parameters <- function(model,parameters=model$parameter){
  model %>%
    rename(old=parameter) %>%
    mutate(parameter=parameters,.after=old)
}

lines_model <- function(model,format='html'){
  if (format=='html'){
    model %>%
      mutate(parameter=str_c('<i>&beta;</i><sub>',parameter,'</sub>')) %>%
      reframe(lines=str_c('(','E(',parameter,') = ',e,', CrI = ',ci,', <i>pd</i> = ',p,')',collapse = '<br>')) %>%
      pull(lines) %>%
      print_html()
  }
  if (format=='latex'){
    model %>%
      mutate(parameter=str_c('$\\beta_\\mathrm{',parameter,'}$')) %>%
      reframe(lines=str_c('(','$\\mathbb{E}$(',parameter,') = ',e,', CrI = ',ci,', \\textit{pd} = ',p,')',collapse = '\n')) %>%
      pull(lines) %>%
      writeLines()
  }
}



# Liste des postérieurs
listposts <- function(model,sel='b_') {
  data.frame(model)%>%
    select(starts_with(sel))%>%
    pivot_longer(cols=everything(),
                 names_prefix = sel,
                 names_ptypes = factor(),
                 names_to = "parameter",
                 values_to = "estimate")
}

# Résumé des postérieurs
sumposts <- function(model,sel='b_',fixed=T){
  posterior_summary(model)%>%
    data.frame()%>%
    rownames_to_column(var='parameter')%>%
    filter(grepl(sel,parameter,fixed=fixed))%>%
    mutate(parameter=gsub(sel,'',parameter,fixed=fixed))%>%
    rename(mean=Estimate,sd=Est.Error,low=Q2.5,up=Q97.5)}

# Plot des postérieurs
plotposts <- function(model,sel='b_',facteurs='all') {
  if ('all'%in%facteurs) {
    listposts(model,sel)%>%
      ggplot(aes(x=estimate))+facet_wrap(~parameter)+
      geom_density(fill='steelblue',col='steelblue',alpha=.7)+
      geom_vline(xintercept = 0,linetype='dashed')
  } else {
    listposts(model,sel)%>%
      filter(parameter%in%facteurs)%>%
      ggplot(aes(x=estimate))+facet_wrap(~parameter)+
      geom_density(fill='steelblue',col='steelblue',alpha=.7)+
      geom_vline(xintercept = 0,linetype='dashed')
  }
}

# Modèle brms
fct_brm <- function(formula,data,family,priors= set_prior('normal(0,1)',class='b'),control=F,adapt_delta=.99,max_treedepth=12,chains=4,iter=4000,warmup=iter/2) {
  if (control == F){controles <- NULL}
  if (control == T){controles <- controles <- list(adapt_delta = adapt_delta, max_treedepth = max_treedepth)}

  model <- brm(formula = {{formula}},
               data = data,
               family=family,
               # Paramètres Bayes
               control = controles,
               prior = priors,
               # Paramètres MCMC
               chains = chains,
               iter = iter,
               warmup = warmup,
               seed = 100)

  return(model)
}

esperance <- function(t,e,fun=logis) {
  F <- fun
  res = c()
  for (i in 1:length(t)) {
    if (i == 1) {res = c(res,F(t[i]-e))}
    else {res = c(res,F(t[i]-e)-F(t[i-1]-e))}
    if (i == length(t)) {res = c(res,1-F(t[i]-e))}
  }
  sum(res*seq(1,length(t)+1,1))
}


