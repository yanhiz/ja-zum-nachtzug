logis.fct <- function(alpha,beta,variable) {
  # Tracer la régression logistique avec les coefficients d'une régression
  exp(alpha+beta*{{variable}})/(1+exp(alpha+beta*{{variable}}))
}

logit <- function(x) {
  # Fonction logit: passer de p à logit(p)
  log(x/(1-x))}


logis <- function(x) {
  # Fonction logistique: passer de logit(p) à p
  plogis(x)}


poiss <- function(k,l) {
  # Fonction poisson: l est le paramètre de moyenne, k est le nombre de compte
  (l^k * exp(-l)) / factorial(k)
}


prop <- function(data,facteur) {
  # Proportion d'une variable binaire 0/1
  library(PropCIs)
  data %>%
    summarise(prop=mean({{facteur}},na.rm=T),n=length({{facteur}}),
              up=exactci(prop*n,n,conf.level = .95)$conf.int[2],
              low=exactci(prop*n,n,conf.level = .95)$conf.int[1])
}

prop_n <- function(data) {
  # Proportion d'un compte n
  data%>%
    mutate(prop=n/sum(n))%>%
    ungroup()
}


prop_n_by <- function(data,facteur,perc=F) {
  # Proportion d'un compte n selon un facteur
  if (perc) {
    data%>%
      mutate(prop=perc(n/sum(n)),.by={{facteur}})
  }
  else {
    data%>%
      mutate(prop=n/sum(n),.by={{facteur}})
  }
}

perc <- function(x,arr=2,acc=1,sign='%') {
  # Pourcentage et arrondissement
  # arr = nombre de chiffres après la virgule en format numérique
  # acc = nombre de chiffres après la virgule en format pourcentage
  percent(round(x,arr),accuracy=acc,suffix=sign)
}

