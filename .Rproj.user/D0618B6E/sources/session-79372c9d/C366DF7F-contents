# Présentation d'un modèle fréquentiste
presentation <- function(model,lignes,arr=2,arr.p=4,Sig=F) {
  summary(model)%>%
    coef()%>%data.frame(row.names=lignes)%>%
    rename(Coefficient='Estimate',`Erreur standard`='Std..Error',`z-value`='z.value',`p-value`='Pr...z..')%>%
    mutate(Seuil=case_when(`p-value`<0.001~'<0.001', `p-value`<0.01~'<0.01',`p-value`<0.05~'<0.05',`p-value`>=0.05~'>0.05'))%>%
    mutate(Sig=case_when(`p-value`<0.001~'***', `p-value`<0.01~'**',`p-value`<0.05~'*',`p-value`<0.1~'.',`p-value`>=0.1~''))%>%
    mutate(across(c(Coefficient,`Erreur standard`,`z-value`),~round(.x,arr)))%>%
    mutate(across(c(`p-value`),~round(.x,arr.p)))-> tableau
  if (Sig==F) {
    tableau %>% select(-Sig)
  }
  else {tableau}
}

