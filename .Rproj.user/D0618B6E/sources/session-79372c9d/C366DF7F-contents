# Corrélation dans un modèle
corr.model <- function(model) {
  as.matrix(cov2cor(vcov(model)))
}

# Corrélation dans des données
corr.data <- function(data,...) {
  data%>%select(!!!ensyms(...))%>%cor(use='complete.obs')
}


# Test de significativité des corrélations
corr.test <- function(mat, ...) {
  mat <- as.matrix(mat)
  n <- ncol(mat)
  p.mat<- matrix(NA, n, n)
  diag(p.mat) <- 0
  for (i in 1:(n - 1)) {
    for (j in (i + 1):n) {
      tmp <- cor.test(mat[, i], mat[, j], ...)
      p.mat[i, j] <- p.mat[j, i] <- tmp$p.value
    }
  }
  colnames(p.mat) <- rownames(p.mat) <- colnames(mat)
  p.mat
}


# Plotter les corrélations
corr.plot <- function(corr) {
  corrplot(corr,order="hclust",p.mat = corr.test(corr), sig.level = 0.01,method = 'square',diag=F, type = 'lower')
  # method = number circle shade color square ellipse pie
  # addrect = chiffre, pour hierarchical clustering
  # type = upper lower
  # nombre : addCoef.col = 'black'
}


